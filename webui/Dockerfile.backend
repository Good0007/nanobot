FROM python:3.12-slim

WORKDIR /app

# Install nanobot + webui deps
COPY pyproject.toml README.md ./
COPY nanobot/ ./nanobot/
COPY webui/ ./webui/

RUN pip install --no-cache-dir -e ".[full]" && \
    pip install --no-cache-dir fastapi uvicorn[standard] PyJWT>=2.8.0 bcrypt python-multipart

EXPOSE 8080

CMD ["python", "-m", "webui", "--port", "8080"]
